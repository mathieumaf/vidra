{
  "name": "vidra",
  "private": true,
  "version": "0.1.0",
  "author": "Mathieu Mafille",
  "license": "GPL-3.0-or-later",
  "packageManager": "pnpm@11.13.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "pnpm build && pnpm test && cargo fmt --manifest-path src-tauri/Cargo.toml --check && cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings && cargo test --manifest-path src-tauri/Cargo.toml",
    "release:check": "node scripts/release/check-version.mjs",
    "ffmpeg:prepare": "node scripts/ffmpeg/prepare.mjs",
    "ffmpeg:release": "VIDRA_FFMPEG_MODE=release node scripts/ffmpeg/prepare.mjs",
    "icon:prepare": "node scripts/icons/prepare-macos.mjs",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "lucide-react": "^1.25.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "~7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
