{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vidra",
  "version": "0.1.0",
  "identifier": "io.github.mathieumaf.vidra",
  "build": {
    "beforeDevCommand": "pnpm icon:prepare && pnpm ffmpeg:prepare && pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm icon:prepare && pnpm ffmpeg:prepare && pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Vidra",
        "width": 1040,
        "height": 720,
        "minWidth": 900,
        "minHeight": 650,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 16,
          "y": 18
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/ffmpeg",
      "binaries/ffprobe"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
